generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum BlogPostStatus {
  draft
  published
}

enum ReservationStatus {
  pending
  paid
  cancelled
}

enum ReservationSource {
  DIRECT
  AIRBNB
  BOOKING
}

enum ReviewSource {
  GOOGLE
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         UserRole      @default(user)
  createdAt    DateTime      @default(now())
  reservations Reservation[]
}

model Bungalow {
  id               String         @id @default(uuid())
  slug             String?        @unique
  title            String
  description      String
  pricePerNight    Decimal        @db.Decimal(10, 2)
  location         String
  images           String[]
  features         Json
  // ICS export token (Airbnb takvime yapistirilan URL); bos satirlarda seed veya ilk talepte uretilir.
  icalExportToken  String?        @unique
  externalIcalUrl  String         @default("")
  googlePlaceId    String?
  createdAt        DateTime       @default(now())
  reservations     Reservation[]
  availability     Availability[]
  rooms            Room[]
  reviews          Review[]
}

model Reservation {
  id           String             @id @default(uuid())
  userId       String
  bungalowId   String
  checkIn      DateTime
  checkOut     DateTime
  guests       Int                @default(1)
  totalPrice   Decimal            @db.Decimal(10, 2)
  status       ReservationStatus  @default(pending)
  source       ReservationSource  @default(DIRECT)
  externalUid  String?
  syncId       String?
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bungalow     Bungalow           @relation(fields: [bungalowId], references: [id], onDelete: Cascade)
  payment      Payment?

  @@index([bungalowId, source])
  @@unique([bungalowId, externalUid])
}

model Review {
  id             String       @id @default(uuid())
  bungalowId     String
  source         ReviewSource @default(GOOGLE)
  authorName     String       @db.VarChar(255)
  text           String       @db.Text
  rating         Int
  googleTimeUnix Int
  reviewedAt     DateTime
  createdAt      DateTime     @default(now())
  bungalow       Bungalow     @relation(fields: [bungalowId], references: [id], onDelete: Cascade)

  @@unique([bungalowId, source, googleTimeUnix, authorName])
  @@index([source, reviewedAt])
}

model Payment {
  id            String   @id @default(uuid())
  reservationId String   @unique
  amount        Decimal  @db.Decimal(10, 2)
  status        String
  provider      String   @default("iyzico")
  createdAt     DateTime @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model Availability {
  id          String   @id @default(uuid())
  bungalowId  String
  date        DateTime
  isAvailable Boolean  @default(true)
  bungalow    Bungalow @relation(fields: [bungalowId], references: [id], onDelete: Cascade)

  @@unique([bungalowId, date])
}

model Translation {
  id  String @id @default(uuid())
  key String @unique
  tr  String
  en  String
  ar  String
}

model Room {
  id            String   @id @default(uuid())
  bungalowId    String
  name          String
  description   String
  capacity      Int
  pricePerNight Decimal  @db.Decimal(10, 2)
  images        String[]
  features      Json
  createdAt     DateTime @default(now())
  bungalow      Bungalow @relation(fields: [bungalowId], references: [id], onDelete: Cascade)
}

model AdminSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentProviderSetting {
  id            String   @id @default(uuid())
  provider      String   @unique
  enabled       Boolean  @default(false)
  mode          String   @default("test")
  publicKey     String?
  secretKey     String?
  webhookSecret String?
  extra         Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MediaAsset {
  id         String   @id @default(uuid())
  url        String
  filename   String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String?
  message    String   @db.Text
  isRead     Boolean  @default(false)
  isReplied  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

// Tek satir SMTP ayarlari (panelden yonetilir; SMTP sifresi AES-GCM ile sifrelenir).
// Cok dilli blog (Markdown govde; SEO icin meta alanlari istege bagli).
model BlogPost {
  id            String          @id @default(uuid())
  slug          String          @unique
  status        BlogPostStatus  @default(draft)
  publishedAt   DateTime?
  titleTr       String
  titleEn       String
  titleAr       String
  excerptTr     String          @db.Text
  excerptEn     String          @db.Text
  excerptAr     String          @db.Text
  bodyTr        String          @db.Text
  bodyEn        String          @db.Text
  bodyAr        String          @db.Text
  metaTitleTr   String?
  metaTitleEn   String?
  metaTitleAr   String?
  metaDescTr    String?         @db.Text
  metaDescEn    String?         @db.Text
  metaDescAr    String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model EmailSettings {
  id                          String   @id @default("default")
  enabled                     Boolean  @default(false)
  host                        String   @default("")
  port                        Int      @default(587)
  secure                      Boolean  @default(false)
  authUser                    String   @default("")
  passwordEnc                 String   @default("")
  fromName                    String   @default("")
  fromEmail                   String   @default("")
  notifyAdminOnNewReservation Boolean @default(true)
  notifyAdminOnContact        Boolean @default(true)
  adminNotifyEmail            String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}
