# Yerel PG sifren farkliysa: scripts/init-bungalov-db.sql ile postgres sifresini esitle
# veya asagidaki URL'de kullanici/sifreyi kendi kurulumuna gore yaz.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bungalov"
# Docker ile backend/docker-compose.yml (port 5433) kullaniyorsan:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/bungalov"
PORT=4000
JWT_SECRET="replace-with-strong-secret"
# Birden fazla koken (virgulle): or. Next 3000 ve 3001
FRONTEND_URL="http://localhost:3000,http://localhost:3001"
BACKEND_URL="http://localhost:4000"
IYZICO_ENABLED="false"
IYZICO_MODE="test"
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""

# Google Places (Place Details) — yorum senkronu; https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_MAPS_API_KEY=""

# SMTP sifresi DB'de AES-256-GCM ile saklanir; uretimde guclu bir deger kullanin (JWT_SECRET'tan farkli olmasi iyi olur).
# EMAIL_ENCRYPTION_KEY="64-karakter-hex-32-byte-ornek-0123456789abcdef0123456789abcdef"
