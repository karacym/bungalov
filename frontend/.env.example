NEXT_PUBLIC_SITE_URL="https://bungalov.savaskara.com"
NEXT_PUBLIC_API_URL="https://api.savaskara.com/api"

# Yerel: frontend/.env.local — SITE_URL, tarayicida actigin port ile ayni olmali
# (3000 doluysa: npm run dev:3001 ve NEXT_PUBLIC_SITE_URL=http://localhost:3001)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Sadece siteyi alt yoldan yayinliyorsan (or. Apache http://localhost/bungalov):
# NEXT_PUBLIC_BASE_PATH=/bungalov
# Ayni base ile statik dosyalar icin CDN kullaniyorsan (nadir):
# NEXT_PUBLIC_ASSET_PREFIX=https://cdn.example.com
